#!/usr/bin/env python3
"""
Wallpaper preference engine + recommendation + cleanup (CLI).
Delegates to the brain module. See `brain.py` for the core logic.

Usage:
  wallpaper-brain keep <path>
  wallpaper-brain discard <path>
  wallpaper-brain recommend [N]
  wallpaper-brain cleanup [min]
  wallpaper-brain status
  wallpaper-brain forget <path>
"""
import random
import subprocess
import sys
from pathlib import Path

from waypaper.brain import (
    keep as brain_keep,
    discard as brain_discard,
    forget as brain_forget,
    load_prefs,
    wid_from,
    get_stats,
    get_status,
    PREFS_PATH,
    LIBRARY_DIR,
)

DOWNLOADER = Path.home() / ".local/bin/wallhaven-download"
LIFETIME_MIN = 20


def cmd_keep(path):
    prefs = brain_keep(path)
    wid = wid_from(path)
    info = prefs.get("kept", {}).get(wid, {})
    n_tags = len(info.get("tags", []))
    print(f"♥ Kept {wid} ({'local' if wid.startswith('local_') else str(n_tags) + ' tags'})")


def cmd_discard(path):
    wid = wid_from(path)
    if not wid:
        print(f"✗ No Wallhaven ID en {Path(path).name}")
        return
    brain_discard(path)
    print(f"✕ Discarded {wid}")


def cmd_forget(path):
    wid = wid_from(path)
    brain_forget(path)
    print(f"Olvidado {wid}")


def cmd_recommend(n=8):
    prefs = load_prefs()
    if not prefs.get("tag_weights"):
        print("Sin preferencias aún. Descargando random...")
        subprocess.run([str(DOWNLOADER), "-n", str(n)], timeout=120)
        return
    sorted_tags = sorted(prefs["tag_weights"].items(), key=lambda x: -x[1])
    top_tags = [t for t, _ in sorted_tags[:8]]
    exclude = {"anime", "digital painting", "artwork", "minimal", "simple background"}
    candidates = [t for t in top_tags if t not in exclude]
    if not candidates:
        chosen = sorted_tags[0][0] if sorted_tags else ""
    elif random.random() < 0.3:
        weights = [w for _, w in sorted_tags[:12]]
        total = sum(weights)
        r = random.uniform(0, total)
        cum = 0
        chosen = sorted_tags[-1][0]
        for t, w in sorted_tags[:12]:
            cum += w
            if r <= cum:
                chosen = t
                break
    else:
        chosen = random.choice(candidates)
    print(f"Recomendando basado en: '{chosen}'")
    purity = "110" if any("sketch" in t for t in top_tags[:3]) else "100"
    subprocess.run([str(DOWNLOADER), "-n", str(n), "-q", chosen, "--purity", purity], timeout=120)
    prefs["last_recommend"] = __import__("time").strftime("%Y-%m-%dT%H:%M:%S")
    from waypaper.brain import save_prefs
    save_prefs(prefs)


def cmd_cleanup(age_min=LIFETIME_MIN):
    import time as _time
    prefs = load_prefs()
    now = _time.time()
    cutoff = now - age_min * 60
    kept = set(prefs.get("kept", {}).keys())
    deleted = 0
    for f in sorted(LIBRARY_DIR.iterdir()):
        if not f.is_file():
            continue
        wid = wid_from(f)
        if wid and wid in kept:
            continue
        if f.stat().st_mtime < cutoff:
            f.unlink()
            deleted += 1
            if wid:
                prefs.setdefault("discarded", {})[wid] = {
                    "path": str(f),
                    "time": _time.strftime("%Y-%m-%dT%H:%M:%S"),
                }
    prefs["last_cleanup"] = _time.strftime("%Y-%m-%dT%H:%M:%S")
    from waypaper.brain import save_prefs
    save_prefs(prefs)
    print(f"Limpiados {deleted} wallpapers")


def cmd_status():
    stats = get_stats()
    print(f"En disco: {stats['total_on_disk']}")
    print(f"♥ Kept: {stats['kept_count']}")
    print(f"✕ Descartados: {stats['discarded_count']}")
    if stats["top_tags"]:
        tag_strs = [f'{t["tag"]}({t["weight"]:.0f})' for t in stats["top_tags"]]
        print(f"Tags: {', '.join(tag_strs)}")
    if stats["last_recommend"]:
        print(f"Última recomendación: {stats['last_recommend']}")
    if stats["last_cleanup"]:
        print(f"Último cleanup: {stats['last_cleanup']}")


if __name__ == "__main__":
    cmds = {
        "keep": lambda: cmd_keep(sys.argv[2]) if len(sys.argv) >= 3 else None,
        "discard": lambda: cmd_discard(sys.argv[2]) if len(sys.argv) >= 3 else None,
        "forget": lambda: cmd_forget(sys.argv[2]) if len(sys.argv) >= 3 else None,
        "recommend": lambda: cmd_recommend(int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2].isdigit() else 8),
        "cleanup": lambda: cmd_cleanup(int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2].isdigit() else LIFETIME_MIN),
        "status": cmd_status,
    }
    if len(sys.argv) < 2 or sys.argv[1] not in cmds:
        print(__doc__)
        sys.exit(1)
    cmds[sys.argv[1]]()
