#!/usr/bin/env python3
"""Download wallpapers from Wallhaven (by preset) and open Waypaper"""
import subprocess, sys
from pathlib import Path

DOWNLOADER = Path.home() / ".local/bin/wallhaven-download"
WAYPAPER = Path.home() / ".local/bin/waypaper-gnome"

PRESETS = ["random", "anime", "manga", "sketch", "general"]

if len(sys.argv) > 1 and sys.argv[1] in PRESETS:
    preset = sys.argv[1]
    n = int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2].isdigit() else 10
else:
    preset = "random"
    n = int(sys.argv[1]) if len(sys.argv) > 1 and sys.argv[1].isdigit() else 10

print(f"↓ Descargando {n} wallpapers ({preset}) de Wallhaven...")
subprocess.run([str(DOWNLOADER), "--preset", preset, "-n", str(n)], timeout=120)
subprocess.run([str(WAYPAPER)])
