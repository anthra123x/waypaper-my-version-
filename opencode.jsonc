{
  "name": "waypaper-my-version",
  "version": "2.8.0.dev1",
  "description": "Waypaper fork with Wallhaven integration + wallpaper-brain recommendation engine",
  "instructions": [
    "~/.opencode/skills/waypaper-project/SKILL.md",
  ],
  "commands": {
    "wp-status": {
      "description": "Show wallpaper-brain stats (kept, discarded, top tags)",
      "command": "wallpaper-brain status"
    },
    "wp-vault": {
      "description": "Open the waypaper Obsidian vault",
      "command": "flatpak run md.obsidian.Obsidian open?vault=$HOME/waypaper-brain"
    },
    "wp-push": {
      "description": "Commit and push all changes to remote",
      "command": "cd $HOME/projects/waypaper-my-version && git add -A && git commit && git push"
    },
  }
}
